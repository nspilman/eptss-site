{
  "lexicon": 1,
  "id": "site.eptss.roundPrompt",
  "defs": {
    "main": {
      "type": "record",
      "description": "A creative prompt or instruction attached to a round. A round may have multiple prompts.",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["round", "promptText", "createdAt"],
        "properties": {
          "round": {
            "type": "string",
            "format": "at-uri",
            "description": "AT-URI of the site.eptss.round record this prompt belongs to."
          },
          "promptText": {
            "type": "string",
            "maxLength": 5000
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
